/// @brief Freestanding <cmath> shim for etl::format floating-point support.
/// @todo Remove when C++26 freestanding <cmath> is available.
///
/// The system <cmath> is unavailable in -ffreestanding mode.
/// ETL's format.h unconditionally includes <cmath> for isnan/isinf.
/// This shim provides the minimum surface needed by etl::format
/// using GCC/Clang __builtin intrinsics (no library dependency).
///
/// Strategy:
///   - <math.h> provides C-linkage double versions of math functions.
///   - C99 isnan/isinf may be macros — we #undef and replace with overloads.
///   - We add float and long double overloads that <math.h> lacks.
///   - We mirror everything into namespace std for C++ callers.

#ifndef SIMPLEKERNEL_SRC_LIBCXX_INCLUDE_CMATH_
#define SIMPLEKERNEL_SRC_LIBCXX_INCLUDE_CMATH_

#pragma GCC system_header

// Pull in the C <math.h> wrapper (src/libc/include/math.h)
// which uses #include_next to get the toolchain's <math.h>.
// This gives us the C double-precision functions at global scope.
#include <math.h>

// C99 isnan/isinf/isfinite may be macros — remove them so we can
// provide proper C++ function overloads.
#undef isnan
#undef isinf
#undef isfinite

// ---------------------------------------------------------------------------
// Global-scope overloads (ETL calls math functions unqualified)
// ---------------------------------------------------------------------------
// isnan / isinf — all three type overloads (macros were removed above)
inline bool isnan(float x) { return __builtin_isnan(x); }
inline bool isnan(double x) { return __builtin_isnan(x); }
inline bool isnan(long double x) { return __builtin_isnan(x); }

inline bool isinf(float x) { return __builtin_isinf(x); }
inline bool isinf(double x) { return __builtin_isinf(x); }
inline bool isinf(long double x) { return __builtin_isinf(x); }

// float and long double overloads for functions where <math.h> only has double.
// The double versions already exist from <math.h> — do NOT redeclare them.
inline float fabs(float x) { return __builtin_fabsf(x); }
inline long double fabs(long double x) { return __builtin_fabsl(x); }

inline float fmod(float x, float y) { return __builtin_fmodf(x, y); }
inline long double fmod(long double x, long double y) {
  return __builtin_fmodl(x, y);
}

inline float log10(float x) { return __builtin_log10f(x); }
inline long double log10(long double x) { return __builtin_log10l(x); }

inline float pow(float x, float y) { return __builtin_powf(x, y); }
inline long double pow(long double x, long double y) {
  return __builtin_powl(x, y);
}

inline float floor(float x) { return __builtin_floorf(x); }
inline long double floor(long double x) { return __builtin_floorl(x); }

inline float ceil(float x) { return __builtin_ceilf(x); }
inline long double ceil(long double x) { return __builtin_ceill(x); }

inline float round(float x) { return __builtin_roundf(x); }
inline long double round(long double x) { return __builtin_roundl(x); }

inline float modf(float x, float* iptr) {
  double di;
  double result = __builtin_modf(static_cast<double>(x), &di);
  *iptr = static_cast<float>(di);
  return static_cast<float>(result);
}
inline long double modf(long double x, long double* iptr) {
  return __builtin_modfl(x, iptr);
}

// ---------------------------------------------------------------------------
// namespace std — mirror everything so std::-qualified calls also work.
// ---------------------------------------------------------------------------
namespace std {

using ::isnan;
using ::isinf;
using ::fabs;
using ::fmod;
using ::log10;
using ::pow;
using ::floor;
using ::ceil;
using ::round;
using ::modf;

}  // namespace std

#endif  // SIMPLEKERNEL_SRC_LIBCXX_INCLUDE_CMATH_
